# 五常同城项目配置文件模板
# 复制此文件为 config.yaml 并修改相应配置

# 服务配置
server:
  host: "0.0.0.0"
  port: 8080
  mode: "debug"  # debug, release, test

# 数据库配置
database:
  host: "localhost"
  port: 5432
  user: "postgres"
  password: "postgres123"
  dbname: "wuchang_tongcheng"
  sslmode: "disable"
  timezone: "Asia/Shanghai"
  # 连接池配置
  max_open_conns: 100
  max_idle_conns: 10
  max_lifetime: 3600  # 秒

# Redis配置
redis:
  host: "localhost"
  port: 6379
  password: "redis123"
  db: 0
  pool_size: 10
  default_expiration: 3600  # 秒

# 日志配置
logger:
  level: "info"  # debug, info, warn, error
  filename: "./logs/app.log"
  max_size: 100       # MB
  max_backups: 3
  max_age: 30         # 天
  compress: false
  console: true

# JWT配置
jwt:
  secret: "wuchang-tongcheng-secret-key-change-in-production"
  expire: 24  # 过期时间（小时）
  issuer: "wuchang-tongcheng"

# RabbitMQ配置
rabbitmq:
  host: "localhost"
  port: 5672
  user: "admin"
  password: "admin123"
  vhost: "/wuchang"

# Elasticsearch配置
elasticsearch:
  addresses:
    - "http://localhost:9200"
  username: ""
  password: ""

# 对象存储配置
storage:
  type: "local"  # local（本地磁盘）| minio（S3协议，兼容AWS S3/阿里云OSS/腾讯云COS）| qiniu（七牛云Kodo，AK/SK未配置时自动降级local）
  access_key: "your-access-key"     # minio/qiniu: access key
  secret_key: "your-secret-key"    # minio/qiniu: secret key
  bucket: "wuchang-tongcheng"       # local: 存储目录(默认./uploads)；minio: 桶名；qiniu: 存储空间名
  domain: "http://localhost:9000"  # local: 访问域名(默认http://localhost:8080)；minio: 服务端点；qiniu: CDN/源站域名
  region: "us-east-1"               # minio: 区域（本地MinIO可用us-east-1）

# 地图服务配置
map:
  type: "amap"  # amap, baidu
  key: "your-map-api-key"
